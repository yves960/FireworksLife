---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingMinutes = Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 220));
const postSlug = post.id;
const postTitle = post.data.title;
---

<Base title={post.data.title} description={post.data.description}>
  <article class="blog-post">
    <a href="/" class="back-link reveal" style="--reveal-delay: 0">返回首页</a>

    <header class="post-hero reveal" style="--reveal-delay: 1">
      <div class="hero-topline">
        <span>{post.data.category}</span>
        {post.data.subTag && <span>{post.data.subTag}</span>}
      </div>

      <div class="hero-layout">
        <div class="hero-copy">
          <h1>{post.data.title}</h1>
          <p class="post-summary">{post.data.description}</p>

          <div class="post-meta">
            <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <div class="meta-tags">
              {(post.data.tags || []).map((tag) => <span>{tag}</span>)}
            </div>
          </div>

          <div class="engagement-bar" data-post-slug={postSlug} data-post-title={postTitle}>
            <button type="button" class="engage-button" id="likeButton">
              <span>点赞</span>
              <strong id="likeCount">0</strong>
            </button>
            <button type="button" class="engage-button" id="favoriteButton">
              <span>收藏</span>
              <strong id="favoriteState">未收藏</strong>
            </button>
          </div>
        </div>

        <aside class="meta-panel" data-spotlight>
          <p class="meta-panel-kicker">Reading Brief</p>
          <div class="meta-grid">
            <div>
              <span class="meta-label">阅读时长</span>
              <strong>{readingMinutes} min</strong>
            </div>
            <div>
              <span class="meta-label">栏目</span>
              <strong>{post.data.category}</strong>
            </div>
          </div>
          {headings.length > 0 && (
            <div class="toc-block">
              <p class="meta-label">章节导航</p>
              <ul>
                {headings.slice(0, 5).map((heading) => (
                  <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>
    </header>

    <div class="content-shell reveal" style="--reveal-delay: 2">
      <div class="reading-rail" aria-hidden="true">
        <span></span>
      </div>
      <div class="content">
        <Content />
      </div>
      <aside class="quote-panel">
        <p class="quote-kicker">Margin Note</p>
        <blockquote>内容不只是被阅读，也应该被布置。页面的节奏，本身就是表达的一部分。</blockquote>
        <p class="quote-note">这里保留杂志边栏感，让长文阅读不至于只剩一条纯正文通道。</p>
      </aside>
    </div>

    <section class="comments-shell reveal" style="--reveal-delay: 3" data-post-slug={postSlug} data-post-title={postTitle}>
      <div class="comments-head">
        <div>
          <p class="quote-kicker">Comments</p>
          <h2>留言板</h2>
        </div>
        <p class="comments-note">评论、点赞和收藏会通过 Netlify Functions 存储，不再只是留在本地浏览器。</p>
      </div>

      <form class="comment-form" id="commentForm">
        <input id="commentAuthor" type="text" maxlength="24" placeholder="你的名字" />
        <textarea id="commentContent" rows="4" maxlength="300" placeholder="写点想法、反馈或者吐槽"></textarea>
        <button type="submit" class="comment-submit">发布评论</button>
      </form>

      <div class="comment-list" id="commentList"></div>
      <p class="comment-empty" id="commentEmpty">还没有评论，来留下第一条。</p>
    </section>

    <div class="post-end reveal" style="--reveal-delay: 4">
      <a href="/" class="back-link">继续逛首页</a>
    </div>
  </article>
</Base>

<script>
  const engagementBar = document.querySelector('.engagement-bar') as HTMLElement | null;
  const commentsShell = document.querySelector('.comments-shell') as HTMLElement | null;
  const likeButton = document.getElementById('likeButton') as HTMLButtonElement | null;
  const favoriteButton = document.getElementById('favoriteButton') as HTMLButtonElement | null;
  const likeCount = document.getElementById('likeCount');
  const favoriteState = document.getElementById('favoriteState');
  const commentForm = document.getElementById('commentForm') as HTMLFormElement | null;
  const commentAuthor = document.getElementById('commentAuthor') as HTMLInputElement | null;
  const commentContent = document.getElementById('commentContent') as HTMLTextAreaElement | null;
  const commentList = document.getElementById('commentList');
  const commentEmpty = document.getElementById('commentEmpty');

  const postSlug = engagementBar?.dataset.postSlug || commentsShell?.dataset.postSlug || '';
  const postTitle = engagementBar?.dataset.postTitle || commentsShell?.dataset.postTitle || '';

  const clientIdKey = 'yufu:client-id';
  const getClientId = () => {
    let current = localStorage.getItem(clientIdKey);
    if (!current) {
      current = crypto.randomUUID();
      localStorage.setItem(clientIdKey, current);
    }
    return current;
  };

  const renderComments = (items: Array<{ author: string; content: string; createdAt: string }>) => {
    if (!commentList || !commentEmpty) return;

    commentList.innerHTML = items
      .slice()
      .reverse()
      .map((item) => `
        <article class="comment-item">
          <div class="comment-item-head">
            <strong>${item.author}</strong>
            <time>${new Date(item.createdAt).toLocaleString('zh-CN')}</time>
          </div>
          <p>${item.content}</p>
        </article>
      `)
      .join('');

    commentEmpty.style.display = items.length ? 'none' : 'block';
  };

  const syncEngagement = () => {
    if (!postSlug) return Promise.resolve();

    return fetch(`/.netlify/functions/engagement?slug=${encodeURIComponent(postSlug)}`, {
      headers: {
        'x-client-id': getClientId(),
      },
    })
      .then((response) => response.json())
      .then((data) => {
        if (likeCount) {
          likeCount.textContent = String(data.likesCount || 0);
        }

        if (favoriteState) {
          favoriteState.textContent = data.favorited ? '已收藏' : '未收藏';
        }

        likeButton?.classList.toggle('is-active', Boolean(data.liked));
        favoriteButton?.classList.toggle('is-active', Boolean(data.favorited));
        renderComments(Array.isArray(data.comments) ? data.comments : []);
      })
      .catch(() => {
        if (commentEmpty) {
          commentEmpty.textContent = '互动服务暂时不可用。';
          commentEmpty.style.display = 'block';
        }
      });
  };

  likeButton?.addEventListener('click', () => {
    if (!postSlug) return;
    fetch('/.netlify/functions/engagement', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-client-id': getClientId(),
      },
      body: JSON.stringify({ slug: postSlug, action: 'like' }),
    }).then(() => syncEngagement());
  });

  favoriteButton?.addEventListener('click', () => {
    if (!postSlug) return;
    fetch('/.netlify/functions/engagement', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-client-id': getClientId(),
      },
      body: JSON.stringify({ slug: postSlug, title: postTitle, action: 'favorite' }),
    }).then(() => syncEngagement());
  });

  commentForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!postSlug || !commentAuthor || !commentContent) return;

    const author = commentAuthor.value.trim() || '匿名';
    const content = commentContent.value.trim();
    if (!content) return;

    fetch('/.netlify/functions/engagement', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-client-id': getClientId(),
      },
      body: JSON.stringify({ slug: postSlug, action: 'comment', author, content }),
    }).then(() => {
      commentContent.value = '';
      syncEngagement();
    });
  });

  syncEngagement();
</script>

<style>
  .blog-post {
    max-width: 1120px;
    margin: 0 auto;
    padding: 1rem 0 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.8rem;
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    color: var(--text-secondary);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    transition:
      color 0.25s ease,
      transform 0.25s ease,
      border-color 0.25s ease;
  }

  .back-link:hover {
    color: var(--text-primary);
    transform: translateY(-2px);
    border-color: rgba(255, 179, 71, 0.35);
  }

  .post-hero,
  .content-shell {
    position: relative;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: linear-gradient(180deg, rgba(9, 17, 31, 0.8), rgba(12, 24, 43, 0.72));
    backdrop-filter: blur(16px);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.18);
  }

  .post-hero {
    margin-top: 1rem;
    padding: clamp(1.8rem, 4vw, 3rem);
    overflow: hidden;
  }

  .post-hero::after {
    content: "";
    position: absolute;
    inset: auto -5rem -5rem auto;
    width: 18rem;
    height: 18rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 122, 24, 0.22), transparent 70%);
    pointer-events: none;
  }

  .hero-topline {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .hero-topline span,
  .meta-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
  }

  .hero-topline span {
    background: rgba(255, 255, 255, 0.06);
    color: var(--accent-soft);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 1.2rem;
    align-items: end;
  }

  .post-hero h1 {
    max-width: 12ch;
    font-size: clamp(2.8rem, 6vw, 5.1rem);
    line-height: 0.97;
    letter-spacing: -0.05em;
  }

  .post-summary {
    max-width: 42rem;
    margin-top: 1.2rem;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 1.6rem;
    color: var(--text-muted);
  }

  .engagement-bar {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.2rem;
  }

  .engage-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 3rem;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease;
  }

  .engage-button:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 179, 71, 0.35);
  }

  .engage-button strong {
    color: var(--accent-soft);
    font-size: 0.86rem;
  }

  .engage-button.is-active {
    background: linear-gradient(135deg, rgba(255, 122, 24, 0.18), rgba(94, 234, 212, 0.12));
    border-color: rgba(255, 179, 71, 0.36);
  }

  .meta-tags {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .meta-tags span {
    background: rgba(94, 234, 212, 0.1);
    color: var(--accent-cool);
  }

  .meta-panel,
  .quote-panel {
    position: relative;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }

  .meta-panel {
    padding: 1.2rem;
    transform-style: preserve-3d;
    transform: perspective(1200px) rotateX(var(--rotate-x, 0deg)) rotateY(var(--rotate-y, 0deg));
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .meta-panel:hover {
    border-color: rgba(255, 179, 71, 0.22);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.16);
  }

  .meta-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at var(--spot-x, 50%) var(--spot-y, 50%), rgba(255, 255, 255, 0.16), transparent 34%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .meta-panel:hover::before {
    opacity: 1;
  }

  .meta-panel-kicker,
  .quote-kicker {
    color: var(--accent-cool);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    margin-bottom: 0.9rem;
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .meta-label {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-bottom: 0.35rem;
  }

  .meta-grid strong {
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .toc-block {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .toc-block ul {
    list-style: none;
  }

  .toc-block li + li {
    margin-top: 0.55rem;
  }

  .toc-block a {
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.6;
  }

  .toc-block a:hover {
    color: var(--text-primary);
  }

  .content-shell {
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr) 250px;
    gap: 0;
    margin-top: 1.5rem;
    overflow: hidden;
  }

  .reading-rail {
    position: relative;
    min-height: 100%;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent);
  }

  .reading-rail span {
    position: sticky;
    top: 7rem;
    display: block;
    width: 2px;
    height: 8rem;
    margin: 3rem auto 0;
    background: linear-gradient(180deg, var(--accent), var(--accent-cool));
    box-shadow: 0 0 28px rgba(255, 122, 24, 0.28);
  }

  .content {
    padding: clamp(1.5rem, 4vw, 3rem);
    font-family: "Noto Serif SC", serif;
    font-size: 1.08rem;
    line-height: 2;
    color: #edf2ff;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    font-family: "Space Grotesk", sans-serif;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    color: #fff4df;
    scroll-margin-top: 6rem;
  }

  .content :global(h2) {
    margin-top: 3rem;
    font-size: 1.95rem;
  }

  .content :global(h3) {
    margin-top: 2.2rem;
    font-size: 1.45rem;
  }

  .content :global(p),
  .content :global(ul),
  .content :global(ol),
  .content :global(blockquote),
  .content :global(pre) {
    margin-bottom: 1.4rem;
  }

  .content :global(p:first-of-type::first-letter) {
    float: left;
    margin-right: 0.4rem;
    line-height: 0.88;
    font-size: 4rem;
    font-family: "Space Grotesk", sans-serif;
    color: #fff1d8;
  }

  .content :global(a) {
    color: var(--accent-soft);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .content :global(strong) {
    color: #fff4df;
  }

  .content :global(code) {
    padding: 0.14rem 0.45rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #ffd9a6;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.9em;
  }

  .content :global(pre) {
    padding: 1.25rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(5, 10, 19, 0.82);
    overflow-x: auto;
  }

  .content :global(pre code) {
    padding: 0;
    background: none;
    color: #dce7fb;
  }

  .content :global(blockquote) {
    padding: 1.2rem 1.4rem;
    border-left: 3px solid var(--accent);
    border-radius: 0 18px 18px 0;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-secondary);
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.4rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(img) {
    max-width: 100%;
    border-radius: 22px;
    margin: 1.6rem 0;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 2.5rem 0;
  }

  .quote-panel {
    padding: 1.4rem 1.2rem;
  }

  .quote-panel blockquote {
    color: #fff1d8;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .quote-note {
    margin-top: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .comments-shell {
    margin-top: 1.5rem;
    padding: clamp(1.4rem, 4vw, 2rem);
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: linear-gradient(180deg, rgba(9, 17, 31, 0.78), rgba(12, 24, 43, 0.72));
    backdrop-filter: blur(16px);
    box-shadow: 0 18px 60px rgba(0, 0, 0, 0.18);
  }

  .comments-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1rem;
  }

  .comments-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
  }

  .comments-note {
    max-width: 32rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .comment-form {
    display: grid;
    gap: 0.8rem;
  }

  .comment-form input,
  .comment-form textarea {
    width: 100%;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
    font: inherit;
    padding: 0.9rem 1rem;
  }

  .comment-form textarea {
    resize: vertical;
    min-height: 7rem;
  }

  .comment-form input:focus,
  .comment-form textarea:focus {
    outline: none;
    border-color: rgba(255, 179, 71, 0.55);
    box-shadow: 0 0 0 5px rgba(255, 122, 24, 0.12);
  }

  .comment-submit {
    justify-self: start;
    min-height: 3rem;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-soft));
    color: #08111f;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .comment-list {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.2rem;
  }

  .comment-item {
    padding: 1rem 1rem 1.05rem;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
  }

  .comment-item-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .comment-item p,
  .comment-empty {
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .comment-empty {
    margin-top: 1rem;
  }

  .post-end {
    margin-top: 1.5rem;
  }

  @media (max-width: 980px) {
    .hero-layout {
      grid-template-columns: 1fr;
    }

    .content-shell {
      grid-template-columns: 74px minmax(0, 1fr);
    }

    .quote-panel {
      display: none;
    }

    .comments-head {
      flex-direction: column;
      align-items: start;
    }
  }

  @media (max-width: 820px) {
    .content-shell {
      grid-template-columns: 1fr;
    }

    .reading-rail {
      display: none;
    }

    .content {
      border-right: none;
    }
  }

  @media (max-width: 720px) {
    .post-hero,
    .content-shell,
    .comments-shell {
      border-radius: 22px;
    }

    .post-hero h1 {
      max-width: none;
    }

    .meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
