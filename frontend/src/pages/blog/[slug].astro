---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title}>
  <article class="blog-post">
    <a href="/" class="back">← 返回首页</a>
    <header>
      <h1>{post.data.title}</h1>
      <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      <span class="post-category">{post.data.category}</span>
      {post.data.subTag && <span class="post-subtag">{post.data.subTag}</span>}
      <span class="post-date">{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</span>
    </header>
    <div class="content">
      <Content />
    </div>
    <a href="/" class="back">← 返回首页</a>
  </article>
</Base>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .back {
    display: inline-block;
    margin-bottom: 2rem;
    color: #8b5cf6;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .back:hover { color: #a78bfa; }

  header { margin-bottom: 2.5rem; }

  header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    background: linear-gradient(135deg, #8b5cf6, #c4b5fd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  header time { color: #64748b; font-size: 0.95rem; }

  .content {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #cbd5e1;
  }

  .content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #c4b5fd;
    font-size: 1.5rem;
  }

  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #a78bfa;
    font-size: 1.25rem;
  }

  .content :global(p) { margin-bottom: 1.25rem; }

  .content :global(code) {
    background: rgba(139, 92, 246, 0.15);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
    color: #c4b5fd;
  }

  .content :global(pre) {
    background: rgba(10, 10, 26, 0.8);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    color: #e2e8f0;
  }

  .content :global(blockquote) {
    border-left: 3px solid #8b5cf6;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #94a3b8;
    font-style: italic;
  }

  .content :global(ul), .content :global(ol) {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .content :global(li) { margin-bottom: 0.5rem; }

  .content :global(a) { color: #8b5cf6; text-decoration: underline; }
  .content :global(a:hover) { color: #a78bfa; }

  .content :global(img) {
    max-width: 100%;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid rgba(139, 92, 246, 0.2);
    margin: 2rem 0;
  }
</style>
