---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Base title="FireworksLife">
  <div class="stars"></div>

  <section class="hero">
    <h1 class="glow-title">FireworksLife</h1>
    <p class="subtitle">时间不在于你拥有多少，而在于你如何使用 ⏱️</p>
  </section>

  <section class="posts">
    <h2>最新文章</h2>
    <div class="card-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="card">
          <h3>{post.data.title}</h3>
          <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
          <p>{post.data.description || ''}</p>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  /* Stars background */
  .stars {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6) 50%, transparent 100%),
      radial-gradient(1px 1px at 30% 60%, rgba(255,255,255,0.4) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 50% 10%, rgba(139,92,246,0.6) 50%, transparent 100%),
      radial-gradient(1px 1px at 70% 80%, rgba(255,255,255,0.5) 50%, transparent 100%),
      radial-gradient(1px 1px at 90% 40%, rgba(255,255,255,0.3) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 15% 75%, rgba(139,92,246,0.4) 50%, transparent 100%),
      radial-gradient(1px 1px at 85% 15%, rgba(255,255,255,0.5) 50%, transparent 100%),
      radial-gradient(1px 1px at 45% 45%, rgba(255,255,255,0.3) 50%, transparent 100%),
      radial-gradient(1px 1px at 60% 90%, rgba(255,255,255,0.4) 50%, transparent 100%),
      radial-gradient(1.2px 1.2px at 25% 35%, rgba(139,92,246,0.5) 50%, transparent 100%);
    animation: twinkle 4s ease-in-out infinite alternate;
  }

  @keyframes twinkle {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 6rem 0 4rem;
    background: linear-gradient(135deg, #0a0a1a 0%, #1a0a2e 50%, #0a1a2e 100%);
    border-radius: 1rem;
    margin-bottom: 3rem;
  }

  .glow-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    background: linear-gradient(135deg, #8b5cf6, #a78bfa, #c4b5fd, #8b5cf6);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: float 3s ease-in-out infinite, gradient-shift 5s ease infinite;
    text-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .subtitle {
    margin-top: 1rem;
    color: #94a3b8;
    font-size: 1.1rem;
    font-weight: 300;
  }

  .posts { position: relative; z-index: 1; }

  .posts h2 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #c4b5fd;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: block;
    background: rgba(26, 10, 46, 0.5);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: rgba(139, 92, 246, 0.5);
    box-shadow: 0 0 25px rgba(139, 92, 246, 0.2), 0 0 60px rgba(139, 92, 246, 0.1);
    transform: translateY(-3px);
  }

  .card h3 { font-size: 1.2rem; color: #e2e8f0; margin-bottom: 0.5rem; }

  .card time { font-size: 0.85rem; color: #64748b; display: block; margin-bottom: 0.75rem; }

  .card p { color: #94a3b8; font-size: 0.95rem; line-height: 1.6; }
</style>
