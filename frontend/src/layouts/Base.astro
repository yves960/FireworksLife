---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "鱼腹 - 一个更有舞台感的个人博客" } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Noto+Serif+SC:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-aurora" aria-hidden="true">
      <span class="orb orb-a"></span>
      <span class="orb orb-b"></span>
      <span class="orb orb-c"></span>
      <span class="grid"></span>
      <span class="noise"></span>
    </div>

    <div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>

    <div class="pet-sprite" id="petSprite" aria-hidden="true" data-mood="idle" data-state="active">
      <span class="pet-aura"></span>
      <span class="pet-trail"></span>
      <span class="pet-core">
        <span class="pet-halo"></span>
        <span class="pet-fin pet-fin-top"></span>
        <span class="pet-fin pet-fin-side"></span>
        <span class="pet-tail"></span>
        <span class="pet-cheek pet-cheek-a"></span>
        <span class="pet-cheek pet-cheek-b"></span>
        <span class="pet-scale pet-scale-a"></span>
        <span class="pet-scale pet-scale-b"></span>
        <span class="pet-face">
          <span class="pet-eye"></span>
          <span class="pet-eye pet-eye-glint"></span>
          <span class="pet-eye pet-eye-sleep"></span>
          <span class="pet-mouth"></span>
          <span class="pet-mouth pet-mouth-excited"></span>
        </span>
      </span>
      <span class="pet-spark spark-a"></span>
      <span class="pet-spark spark-b"></span>
      <span class="pet-spark spark-c"></span>
      <span class="pet-bubble" id="petBubble">Hi</span>
    </div>

    <nav class="site-nav">
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="logo-mark">FL</span>
          <span class="logo-text">鱼腹</span>
        </a>
        <div class="nav-links">
          <a href="/">首页</a>
          <a href="/about">关于</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>© 2026 鱼腹 · Notes, sparks, and signal.</p>
    </footer>

    <style is:global>
      :root {
        --bg-primary: #07111f;
        --bg-secondary: #0d1a2e;
        --bg-tertiary: #12263f;
        --surface-strong: rgba(8, 16, 31, 0.82);
        --surface-soft: rgba(15, 28, 50, 0.66);
        --surface-outline: rgba(255, 255, 255, 0.1);
        --text-primary: #f7f5ef;
        --text-secondary: #b9c3d5;
        --text-muted: #7e8ca5;
        --accent: #ff7a18;
        --accent-soft: #ffb347;
        --accent-cool: #5eead4;
        --accent-pink: #ff5f9e;
        --shadow-glow: 0 24px 80px rgba(255, 122, 24, 0.18);
        --radius-xl: 32px;
        --radius-lg: 24px;
        --radius-md: 18px;
        --radius-sm: 12px;
        --max-width: 1180px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: "Space Grotesk", sans-serif;
        background:
          radial-gradient(circle at top, rgba(255, 122, 24, 0.18), transparent 28%),
          radial-gradient(circle at 80% 20%, rgba(94, 234, 212, 0.14), transparent 24%),
          linear-gradient(180deg, #050a13 0%, #091320 36%, #0d1a2e 100%);
        color: var(--text-primary);
        min-height: 100vh;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      a {
        color: inherit;
      }

      .page-aurora {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }

      .orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(18px);
        opacity: 0.6;
        mix-blend-mode: screen;
      }

      .orb-a {
        width: 36rem;
        height: 36rem;
        top: -12rem;
        left: -10rem;
        background: radial-gradient(circle, rgba(255, 122, 24, 0.35), transparent 70%);
        animation: drift 16s ease-in-out infinite;
      }

      .orb-b {
        width: 28rem;
        height: 28rem;
        top: 12rem;
        right: -8rem;
        background: radial-gradient(circle, rgba(94, 234, 212, 0.26), transparent 70%);
        animation: drift 18s ease-in-out infinite reverse;
      }

      .orb-c {
        width: 22rem;
        height: 22rem;
        bottom: 8rem;
        left: 50%;
        background: radial-gradient(circle, rgba(255, 95, 158, 0.18), transparent 70%);
        animation: drift 20s ease-in-out infinite;
      }

      .grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
        background-size: 72px 72px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.6), transparent 85%);
      }

      .noise {
        position: absolute;
        inset: 0;
        opacity: 0.08;
        background-image:
          radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.9) 0 0.6px, transparent 0.8px),
          radial-gradient(circle at 80% 40%, rgba(255, 255, 255, 0.7) 0 0.7px, transparent 0.9px),
          radial-gradient(circle at 35% 70%, rgba(255, 255, 255, 0.5) 0 0.7px, transparent 0.9px);
        background-size: 180px 180px;
      }

      .cursor-glow {
        position: fixed;
        left: 0;
        top: 0;
        width: 18rem;
        height: 18rem;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(255, 179, 71, 0.14), rgba(94, 234, 212, 0.08) 40%, transparent 70%);
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 1;
        filter: blur(12px);
        opacity: 0.9;
      }

      .pet-sprite {
        position: fixed;
        left: 0;
        top: 0;
        width: 4.8rem;
        height: 4.8rem;
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 12;
      }

      .pet-aura,
      .pet-trail,
      .pet-core,
      .pet-halo,
      .pet-fin,
      .pet-tail,
      .pet-cheek,
      .pet-scale,
      .pet-face {
        position: absolute;
        inset: 0;
      }

      .pet-aura {
        inset: -0.35rem;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(94, 234, 212, 0.18), rgba(255, 122, 24, 0.08) 44%, transparent 72%);
        filter: blur(20px);
        animation: aura-shift 3.8s ease-in-out infinite;
      }

      .pet-trail {
        inset: 1.2rem auto 1.2rem -0.45rem;
        width: 3.7rem;
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(94, 234, 212, 0.18), rgba(123, 211, 255, 0.18), rgba(255, 193, 120, 0.14), transparent);
        filter: blur(18px);
        animation: pulse-trail 2.2s ease-in-out infinite;
      }

      .pet-core {
        inset: 0.95rem 0.55rem 0.95rem 0.95rem;
        border-radius: 62% 38% 58% 42% / 58% 56% 44% 42%;
        background:
          radial-gradient(circle at 30% 32%, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.3) 16%, transparent 18%),
          radial-gradient(circle at 40% 70%, rgba(255, 255, 255, 0.14), transparent 30%),
          linear-gradient(135deg, rgba(98, 244, 220, 0.96), rgba(92, 191, 255, 0.94) 36%, rgba(255, 182, 96, 0.92) 70%, rgba(255, 132, 178, 0.82));
        box-shadow:
          0 0 24px rgba(80, 170, 255, 0.24),
          0 0 52px rgba(94, 234, 212, 0.16);
        animation: pet-bob 2.4s ease-in-out infinite;
      }

      .pet-halo {
        inset: -0.28rem -0.16rem;
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 62% 38% 58% 42% / 58% 56% 44% 42%;
        animation: spin 8s linear infinite;
      }

      .pet-halo::before,
      .pet-halo::after {
        content: "";
        position: absolute;
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        background: rgba(255, 244, 223, 0.92);
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.4);
      }

      .pet-halo::before {
        top: 0.1rem;
        left: 50%;
        transform: translateX(-50%);
      }

      .pet-halo::after {
        bottom: 0.1rem;
        right: 0.4rem;
      }

      .pet-fin {
        pointer-events: none;
      }

      .pet-fin-top::before {
        content: "";
        position: absolute;
        top: 0.05rem;
        left: 2.05rem;
        width: 1.05rem;
        height: 1rem;
        background: linear-gradient(180deg, rgba(255, 244, 223, 0.82), rgba(94, 234, 212, 0.34));
        clip-path: polygon(50% 0%, 4% 100%, 100% 100%);
        border-radius: 999px 999px 0 0;
        animation: fin-sway 1.2s ease-in-out infinite;
      }

      .pet-fin-side::before {
        content: "";
        position: absolute;
        left: 2.35rem;
        top: 2rem;
        width: 0.92rem;
        height: 0.84rem;
        background: linear-gradient(135deg, rgba(255, 244, 223, 0.84), rgba(255, 140, 96, 0.42));
        clip-path: ellipse(48% 40% at 50% 50%);
        border-radius: 999px;
        opacity: 0.88;
        transform: rotate(16deg);
      }

      .pet-tail::before,
      .pet-tail::after {
        content: "";
        position: absolute;
        left: -0.18rem;
        top: 1.42rem;
        width: 1.28rem;
        height: 1.06rem;
        background: linear-gradient(135deg, rgba(255, 244, 223, 0.88), rgba(94, 234, 212, 0.36));
        clip-path: path("M 20 20 C 2 4, 2 36, 20 20 C 34 6, 34 34, 20 20 Z");
        transform-origin: right center;
        animation: tail-flick 1.1s ease-in-out infinite;
      }

      .pet-tail::after {
        top: 2.1rem;
        left: 0.12rem;
        width: 0.72rem;
        height: 0.5rem;
        opacity: 0.56;
        animation-duration: 1.4s;
      }

      .pet-cheek {
        width: 0.44rem;
        height: 0.3rem;
        border-radius: 999px;
        background: rgba(255, 117, 160, 0.38);
        filter: blur(1px);
        pointer-events: none;
      }

      .pet-cheek-a {
        inset: 2rem auto auto 1.2rem;
      }

      .pet-cheek-b {
        inset: 2.18rem auto auto 1.55rem;
        width: 0.28rem;
        height: 0.2rem;
        opacity: 0.75;
      }

      .pet-scale {
        border-radius: 999px;
        background: radial-gradient(circle, rgba(255, 244, 223, 0.28), transparent 72%);
        pointer-events: none;
      }

      .pet-scale-a {
        inset: 1.7rem 1rem 1.55rem 2rem;
      }

      .pet-scale-b {
        inset: 2.15rem 1.55rem 1.12rem 1.45rem;
      }

      .pet-face {
        display: flex;
        align-items: center;
        justify-content: start;
        gap: 0.14rem;
        padding-top: 1.48rem;
        padding-left: 1rem;
      }

      .pet-eye {
        width: 0.7rem;
        height: 0.7rem;
        background: #08111f;
        border-radius: 999px;
        box-shadow:
          inset -0.08rem -0.08rem 0 0 rgba(255, 255, 255, 0.26),
          0 0 0 0.08rem rgba(255, 255, 255, 0.16);
        animation: blink 4.8s ease-in-out infinite;
        transition:
          transform 0.2s ease,
          opacity 0.2s ease;
      }

      .pet-eye-glint {
        position: absolute;
        inset: 1.66rem auto auto 1.22rem;
        width: 0.18rem;
        height: 0.18rem;
        background: rgba(255, 255, 255, 0.95);
        box-shadow: none;
        animation: none;
      }

      .pet-eye-sleep {
        position: absolute;
        inset: 1.9rem auto auto 1rem;
        width: 0.72rem;
        height: 0.22rem;
        background: transparent;
        border-top: 2px solid #08111f;
        border-radius: 999px;
        box-shadow: none;
        opacity: 0;
        animation: none;
      }

      .pet-mouth {
        position: absolute;
        left: 0.92rem;
        top: 2.38rem;
        width: 0.54rem;
        height: 0.28rem;
        border-bottom: 2px solid #08111f;
        border-radius: 0 0 999px 999px;
        transform: rotate(-3deg);
        transition:
          transform 0.2s ease,
          opacity 0.2s ease,
          width 0.2s ease,
          height 0.2s ease;
      }

      .pet-mouth-excited {
        left: 0.98rem;
        top: 2.22rem;
        width: 0.42rem;
        height: 0.42rem;
        border: 2px solid #08111f;
        border-radius: 999px;
        background: rgba(255, 244, 223, 0.28);
        opacity: 0;
      }

      .pet-spark {
        position: absolute;
        width: 0.36rem;
        height: 0.36rem;
        border-radius: 999px;
        background: rgba(255, 244, 223, 0.95);
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.36);
      }

      .spark-a {
        top: 0.35rem;
        right: 0.4rem;
        animation: spark-float 1.9s ease-in-out infinite;
      }

      .spark-b {
        bottom: 0.7rem;
        left: 0.25rem;
        width: 0.28rem;
        height: 0.28rem;
        animation: spark-float 2.3s ease-in-out infinite reverse;
      }

      .spark-c {
        top: 1.1rem;
        left: -0.15rem;
        width: 0.24rem;
        height: 0.24rem;
        animation: spark-float 2.1s ease-in-out infinite;
      }

      .pet-bubble {
        position: absolute;
        left: 50%;
        top: -1.65rem;
        transform: translateX(-50%) scale(0.9);
        padding: 0.32rem 0.55rem;
        border-radius: 999px;
        background: rgba(7, 17, 31, 0.88);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: #fff3dc;
        font-size: 0.72rem;
        line-height: 1;
        white-space: nowrap;
        opacity: 0;
        transition:
          opacity 0.25s ease,
          transform 0.25s ease;
      }

      .pet-bubble.is-visible {
        opacity: 1;
        transform: translateX(-50%) scale(1);
      }

      .pet-sprite[data-mood="hover"] .pet-core {
        animation-duration: 1.3s;
      }

      .pet-sprite[data-mood="hover"] .pet-eye {
        transform: scale(1.05);
      }

      .pet-sprite[data-mood="hover"] .pet-mouth {
        transform: rotate(0deg) scale(1.08);
      }

      .pet-sprite[data-mood="excited"] .pet-core {
        transform: scale(1.08);
      }

      .pet-sprite[data-mood="excited"] .pet-aura {
        opacity: 1;
      }

      .pet-sprite[data-mood="excited"] .pet-spark {
        background: rgba(94, 234, 212, 0.95);
      }

      .pet-sprite[data-mood="excited"] .pet-eye {
        transform: scale(1.1);
      }

      .pet-sprite[data-mood="excited"] .pet-mouth:not(.pet-mouth-excited) {
        opacity: 0;
      }

      .pet-sprite[data-mood="excited"] .pet-mouth-excited {
        opacity: 1;
        transform: scale(1.08);
      }

      .pet-sprite[data-mood="sleepy"] .pet-eye:not(.pet-eye-sleep):not(.pet-eye-glint) {
        opacity: 0;
      }

      .pet-sprite[data-mood="sleepy"] .pet-eye-glint {
        opacity: 0;
      }

      .pet-sprite[data-mood="sleepy"] .pet-eye-sleep {
        opacity: 1;
      }

      .pet-sprite[data-mood="sleepy"] .pet-mouth:not(.pet-mouth-excited) {
        width: 0.4rem;
        height: 0.14rem;
        top: 2.46rem;
        opacity: 0.72;
      }

      .pet-sprite[data-state="docked"] .pet-aura {
        opacity: 0.45;
        transform: scale(0.82);
      }

      .pet-sprite[data-state="docked"] .pet-fin-top::before {
        animation-duration: 2s;
      }

      .pet-sprite[data-state="docked"] .pet-tail {
        opacity: 0.82;
      }

      .pet-sprite[data-state="docked"] .pet-core {
        animation-duration: 3.2s;
      }

      .site-nav {
        position: sticky;
        top: 0;
        z-index: 10;
        padding: 1.1rem 1.25rem 0;
      }

      .nav-content {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1rem 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 999px;
        background: rgba(6, 12, 24, 0.7);
        backdrop-filter: blur(18px);
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        text-decoration: none;
      }

      .logo-mark {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-soft));
        color: #07111f;
        font-weight: 700;
        box-shadow: 0 0 24px rgba(255, 122, 24, 0.3);
      }

      .logo-text {
        font-size: 1rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        gap: 0.75rem;
      }

      .nav-links a {
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text-secondary);
        transition:
          color 0.25s ease,
          background 0.25s ease,
          transform 0.25s ease;
      }

      .nav-links a:hover {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.06);
        transform: translateY(-1px);
      }

      main {
        position: relative;
        z-index: 1;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 3rem 1.25rem 5rem;
        min-height: calc(100vh - 10rem);
      }

      footer {
        position: relative;
        z-index: 1;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.25rem 3rem;
      }

      footer p {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding-top: 1.25rem;
        color: var(--text-muted);
        font-size: 0.92rem;
      }

      .reveal {
        opacity: 0;
        transform: translateY(34px) scale(0.985);
        transition:
          opacity 0.8s ease,
          transform 0.8s ease;
        transition-delay: calc(var(--reveal-delay, 0) * 120ms);
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      ::selection {
        background: rgba(255, 122, 24, 0.85);
        color: #fff;
      }

      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #08111f;
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, var(--accent), var(--accent-pink));
        border-radius: 999px;
      }

      @keyframes drift {
        0%,
        100% {
          transform: translate3d(0, 0, 0) scale(1);
        }
        50% {
          transform: translate3d(2.5rem, 1rem, 0) scale(1.06);
        }
      }

      @keyframes pulse-trail {
        0%,
        100% {
          transform: scale(0.92);
          opacity: 0.75;
        }
        50% {
          transform: scale(1.12);
          opacity: 1;
        }
      }

      @keyframes aura-shift {
        0%,
        100% {
          transform: scale(0.92);
          opacity: 0.62;
        }
        50% {
          transform: scale(1.06);
          opacity: 1;
        }
      }

      @keyframes pet-bob {
        0%,
        100% {
          transform: translateY(0) rotate(-4deg);
        }
        50% {
          transform: translateY(-0.25rem) rotate(4deg);
        }
      }

      @keyframes tail-flick {
        0%,
        100% {
          transform: rotate(14deg) scale(1);
        }
        50% {
          transform: rotate(-18deg) scale(1.04);
        }
      }

      @keyframes fin-sway {
        0%,
        100% {
          transform: rotate(-8deg) translateY(0);
        }
        50% {
          transform: rotate(8deg) translateY(-0.05rem);
        }
      }

      @keyframes blink {
        0%,
        46%,
        52%,
        100% {
          transform: scaleY(1);
        }
        49% {
          transform: scaleY(0.2);
        }
      }

      @keyframes spark-float {
        0%,
        100% {
          transform: translateY(0) scale(0.85);
          opacity: 0.5;
        }
        50% {
          transform: translateY(-0.45rem) scale(1.1);
          opacity: 1;
        }
      }

      @keyframes spin {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }

        .reveal {
          opacity: 1;
          transform: none;
        }
      }

      @media (max-width: 720px) {
        .site-nav {
          padding-top: 0.75rem;
        }

        .nav-content {
          border-radius: 24px;
          padding: 0.9rem 1rem;
          flex-direction: column;
          gap: 0.9rem;
        }

        .logo-text {
          font-size: 0.92rem;
        }

        .nav-links {
          width: 100%;
          justify-content: center;
        }

        .cursor-glow,
        .pet-sprite {
          display: none;
        }

        main {
          padding-top: 2rem;
        }
      }
    </style>

    <script>
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        const cursorGlow = document.getElementById('cursorGlow');
        const petSprite = document.getElementById('petSprite');
        const petBubble = document.getElementById('petBubble');
        const revealItems = document.querySelectorAll('.reveal');
        const spotlightCards = document.querySelectorAll('[data-spotlight]');
        const interactiveTargets = document.querySelectorAll('a, button, input, textarea, summary');

        let mouseX = window.innerWidth * 0.75;
        let mouseY = window.innerHeight * 0.35;
        let glowX = mouseX;
        let glowY = mouseY;
        let petX = mouseX;
        let petY = mouseY;
        let targetPetX = mouseX;
        let targetPetY = mouseY;
        let moodTimer;
        let lastMoveAt = Date.now();
        let isDocked = false;
        let lastMouseClientX = mouseX;
        let lastMouseClientY = mouseY;

        const dockOffsetX = 120;
        const dockOffsetY = 116;

        const petMessages = {
          idle: ['小鱼', '冒泡', '在线', '游来啦'],
          hover: ['戳这里', '看这个', '游过去', '有东西'],
          excited: ['咕噜!', '亮了', '冲呀', '开摆尾'],
          sleepy: ['停靠中', 'zzZ', '漂一会', '休息']
        };

        function getDockPoint() {
          return {
            x: window.innerWidth - dockOffsetX,
            y: window.innerHeight - dockOffsetY
          };
        }

        function setDocked(nextDocked, message) {
          if (!petSprite) return;
          isDocked = nextDocked;
          petSprite.dataset.state = nextDocked ? 'docked' : 'active';

          if (nextDocked) {
            const dock = getDockPoint();
            targetPetX = dock.x;
            targetPetY = dock.y;
            setPetMood('sleepy', message || '回窝');
          } else {
            targetPetX = mouseX;
            targetPetY = mouseY;
            setPetMood('idle', message || '起飞');
          }
        }

        function setPetMood(mood, forceMessage) {
          if (!petSprite) return;
          petSprite.dataset.mood = mood;

          if (!petBubble) return;
          const pool = petMessages[mood] || petMessages.idle;
          petBubble.textContent = forceMessage || pool[Math.floor(Math.random() * pool.length)];
          petBubble.classList.add('is-visible');

          window.clearTimeout(moodTimer);
          moodTimer = window.setTimeout(() => {
            petBubble.classList.remove('is-visible');
          }, mood === 'excited' ? 1100 : 820);
        }

        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              }
            });
          },
          { threshold: 0.14 }
        );

        revealItems.forEach((item) => revealObserver.observe(item));

        document.addEventListener('mousemove', (event) => {
          mouseX = event.clientX;
          mouseY = event.clientY;
          lastMoveAt = Date.now();
          lastMouseClientX = event.clientX;
          lastMouseClientY = event.clientY;

          const dock = getDockPoint();
          const nearDock = Math.hypot(event.clientX - dock.x, event.clientY - dock.y) < 180;

          if (isDocked && nearDock) {
            setDocked(false, '醒了');
          }

          if (!isDocked && petSprite?.dataset.mood === 'sleepy') {
            setPetMood('idle', '游回来');
          }
        });

        interactiveTargets.forEach((target) => {
          target.addEventListener('pointerenter', () => {
            setPetMood('hover');
          });
        });

        document.addEventListener('click', () => {
          setPetMood('excited');
        });

        window.addEventListener('resize', () => {
          if (isDocked) {
            const dock = getDockPoint();
            targetPetX = dock.x;
            targetPetY = dock.y;
          }
        });

        spotlightCards.forEach((card) => {
          card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const x = event.clientX - rect.left;
            const y = event.clientY - rect.top;
            card.style.setProperty('--spot-x', `${x}px`);
            card.style.setProperty('--spot-y', `${y}px`);
            card.style.setProperty('--rotate-x', `${((y / rect.height) - 0.5) * -8}deg`);
            card.style.setProperty('--rotate-y', `${((x / rect.width) - 0.5) * 10}deg`);
          });

          card.addEventListener('pointerleave', () => {
            card.style.setProperty('--rotate-x', '0deg');
            card.style.setProperty('--rotate-y', '0deg');
          });
        });

        function animate() {
          glowX += (mouseX - glowX) * 0.12;
          glowY += (mouseY - glowY) * 0.12;
          if (!isDocked) {
            targetPetX = mouseX;
            targetPetY = mouseY;
          }
          petX += (targetPetX - petX) * (isDocked ? 0.045 : 0.08);
          petY += (targetPetY - petY) * (isDocked ? 0.045 : 0.08);

          if (Date.now() - lastMoveAt > 2600 && !isDocked) {
            setDocked(true, '回窝');
          }

          if (cursorGlow) {
            cursorGlow.style.transform = `translate(${glowX - 144}px, ${glowY - 144}px)`;
          }

          if (petSprite) {
            petSprite.style.transform = `translate(${petX - 38}px, ${petY - 38}px)`;
            const aimX = (isDocked ? lastMouseClientX : mouseX) - petX;
            petSprite.style.rotate = `${aimX * 0.03}deg`;
          }

          requestAnimationFrame(animate);
        }

        animate();
      } else {
        document.querySelectorAll('.reveal').forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
